# .gitignore file
#
# This file specifies intentionally untracked files that Git should ignore.

## Linux

# Swap files
*.swp

# Temporary files
*~

## macOS

# macOS Finder directory metadata
.DS_Store

# Stores macOS custom file attributes for networked environments
.AppleDouble

# Overrides user-set file settings (e.g., icons, backgrounds)
.LSOverride

# Prevents macOS Spotlight from indexing the directory
.Spotlight-V100

## Windows

# Windows image file caches
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
